---
import BaseLayout from "./BaseLayout.astro";
import { siteConfig } from "../../site.config";
import { jsonLdArticle, jsonLdBreadcrumbs } from "../utils/seo";
import { getCollection } from "astro:content";

interface Source {
  title: string;
  url: string;
  outlet: string;
  date?: Date;
}

interface KeyQuote {
  text: string;
  author: string;
  context?: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category: string;
  impactLevel: number;
  keyQuote?: KeyQuote;
  tldr: string[];
  sources: Source[];
  relatedCalculateurs?: string[];
  relatedGuides?: string[];
  image?: string;
  imageAlt?: string;
  slug: string;
  keywords?: string;
  lastReviewed?: Date;
  reviewedBy?: string;
}

const {
  title,
  description,
  date,
  author = "Econono Décrypte",
  category,
  impactLevel,
  keyQuote,
  tldr,
  sources,
  relatedCalculateurs = [],
  relatedGuides = [],
  image,
  imageAlt,
  slug,
  keywords,
  lastReviewed,
  reviewedBy,
} = Astro.props;

const articleUrl = siteConfig.url + `/actu/${slug}/`;
const dateStr = date.toISOString().split("T")[0];

const CATEGORY_LABELS: Record<string, string> = {
  smic: "SMIC",
  livret: "Livrets épargne",
  aide: "Aides sociales",
  fiscalite: "Fiscalité",
  energie: "Énergie",
  inflation: "Inflation",
  logement: "Logement",
  alerte: "Alerte",
};

const breadcrumbs = jsonLdBreadcrumbs([
  { name: "Accueil", url: siteConfig.url + "/" },
  { name: "Actu", url: siteConfig.url + "/actu/" },
  { name: CATEGORY_LABELS[category] ?? category, url: siteConfig.url + `/actu/categorie/${category}/` },
  { name: title, url: articleUrl },
]);

let allCalcs: Awaited<ReturnType<typeof getCollection>> = [];
let allGuides: Awaited<ReturnType<typeof getCollection>> = [];
try { allCalcs = await getCollection("calculateurs", ({ data }) => !data.draft); } catch {}
try { allGuides = await getCollection("guides", ({ data }) => !data.draft); } catch {}

const calcItems = relatedCalculateurs.map((id) => allCalcs.find((c) => c.id === id)).filter(Boolean) as any[];
const guideItems = relatedGuides.map((id) => allGuides.find((g) => g.id === id)).filter(Boolean) as any[];

const jsonLd = [
  jsonLdArticle({
    title,
    description,
    url: articleUrl,
    datePublished: dateStr,
    image,
    author,
    keywords: keywords?.split(",").map((k) => k.trim()),
  }),
  breadcrumbs,
];
---

<BaseLayout
  title={`${title} · ${siteConfig.name}`}
  description={description}
  canonicalUrl={articleUrl}
  ogImage={image}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-xs uppercase tracking-widest mb-6" style="font-family: var(--font-mono); color: #57534e;">
      <a href="/" class="hover:underline">Accueil</a>
      <span class="mx-2 text-stone-300">›</span>
      <a href="/actu/" class="hover:underline">Actu</a>
      <span class="mx-2 text-stone-300">›</span>
      <a href={`/actu/categorie/${category}/`} class="hover:underline">{CATEGORY_LABELS[category] ?? category}</a>
    </nav>

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <a
          href={`/actu/categorie/${category}/`}
          class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full"
          style="background: rgba(244, 196, 48, 0.18); color: #c2410c; font-family: var(--font-mono);"
        >
          {CATEGORY_LABELS[category] ?? category}
        </a>
        <span class="flex items-center gap-1.5" title={`Impact ${impactLevel}/5`}>
          {Array.from({ length: 5 }, (_, i) => (
            <span class={`block w-2 h-2 rounded-full`} style={`background: ${i < impactLevel ? "#1a3d2e" : "#e7e5e4"}`}></span>
          ))}
          <span class="ml-1 text-xs font-medium" style="color: #57534e; font-family: var(--font-mono);">Impact {impactLevel}/5</span>
        </span>
      </div>

      <h1 style="color: #0f2419; font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 5vw, 3.6rem); line-height: 1.05; letter-spacing: -0.02em;">{title}</h1>
      <p class="text-lg text-stone-600 mt-4 mb-5 leading-relaxed">{description}</p>

      <div class="flex flex-wrap items-center gap-3 text-sm" style="color: #57534e;">
        <span class="font-medium">{author}</span>
        <span class="text-stone-300">·</span>
        <time datetime={dateStr}>
          {date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
        </time>
        {lastReviewed && (
          <>
            <span class="text-stone-300">·</span>
            <span>
              Revu le {lastReviewed.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              {reviewedBy && ` par ${reviewedBy}`}
            </span>
          </>
        )}
      </div>
    </header>

    {image && (
      <figure class="mb-10">
        <img src={image} alt={imageAlt || title} class="w-full rounded-xl" loading="eager" width="1200" height="630" />
      </figure>
    )}

    {/* TL;DR speakable */}
    <aside data-speakable class="mb-10">
      <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #c2410c; font-family: var(--font-mono);">L'essentiel en 30 secondes</p>
      <ul class="space-y-2">
        {tldr.map((point) => (
          <li class="flex gap-3 leading-relaxed text-stone-800">
            <span class="font-bold mt-0.5" style="color: #1a3d2e;">·</span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
    </aside>

    {/* Main content (markdown rendered) */}
    <div class="prose max-w-none mb-12">
      <slot />
    </div>

    {/* Key quote */}
    {keyQuote && (
      <blockquote class="my-12 pull-quote">
        {keyQuote.text}
        <footer class="mt-3 text-sm not-italic" style="color: #57534e; font-family: var(--font-body);">
          <span class="font-semibold" style="color: #0f2419;">— {keyQuote.author}</span>
          {keyQuote.context && <span class="block text-stone-500 mt-0.5">{keyQuote.context}</span>}
        </footer>
      </blockquote>
    )}

    {/* Sources */}
    <section class="ticket p-6 mb-10">
      <p class="eyebrow mb-4 text-xs">Sources vérifiées</p>
      <ul class="space-y-3">
        {sources.map((source) => (
          <li class="text-sm">
            <a href={source.url} target="_blank" rel="noopener nofollow" class="font-medium underline-offset-2 hover:underline" style="color: #1a3d2e;">
              {source.title}
            </a>
            <span class="text-stone-500"> · {source.outlet}</span>
            {source.date && (
              <span class="text-stone-400"> · {source.date.toLocaleDateString("fr-FR", { day: "numeric", month: "short", year: "numeric" })}</span>
            )}
          </li>
        ))}
      </ul>
    </section>

    {/* Related */}
    {(calcItems.length > 0 || guideItems.length > 0) && (
      <section class="border-t border-stone-200 pt-10">
        <p class="eyebrow mb-6">Pour aller plus loin</p>
        <div class="grid sm:grid-cols-2 gap-6">
          {calcItems.length > 0 && (
            <div>
              <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: #c2410c;">Calculateurs liés</p>
              <ul class="space-y-2">
                {calcItems.map((c) => (
                  <li>
                    <a href={`/calculateurs/${c.id}/`} class="text-sm font-medium hover:underline" style="color: #1a3d2e;">
                      {c.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {guideItems.length > 0 && (
            <div>
              <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: #c2410c;">Guides liés</p>
              <ul class="space-y-2">
                {guideItems.map((g) => (
                  <li>
                    <a href={`/guides/${g.id}/`} class="text-sm font-medium hover:underline" style="color: #1a3d2e;">
                      {g.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {/* Back to feed */}
    <div class="mt-12 flex flex-wrap items-center justify-between gap-4">
      <a href="/actu/" class="inline-flex items-center gap-2 font-semibold border-b-2 pb-0.5" style="color: #1a3d2e; border-color: #1a3d2e;">
        ← Tous les décryptages
      </a>
      <a href="/newsletter/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-semibold text-sm text-white" style="background: #1a3d2e;">
        S'abonner au Carnet →
      </a>
    </div>
  </article>
</BaseLayout>
