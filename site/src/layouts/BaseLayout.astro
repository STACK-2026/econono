---
import { siteConfig } from "../../site.config";
import { fontsUrl } from "../utils/config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import Analytics from "../components/Analytics.astro";
import EasterEggs from "../components/EasterEggs.astro";
import AutoGlossaire from "../components/AutoGlossaire.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  articleSection?: string;
  articleTags?: string[];
  jsonLd?: object | object[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = siteConfig.ogImage,
  ogImageAlt = `${siteConfig.name} · ${siteConfig.tagline}`,
  ogType = "website",
  publishedTime,
  modifiedTime,
  author,
  articleSection,
  articleTags = [],
  jsonLd,
  noIndex = false,
} = Astro.props;

const imageUrl = ogImage?.startsWith("http") ? ogImage : `${siteConfig.url}${ogImage}`;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={siteConfig.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a3d2e" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f2419" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light" />
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="application-name" content="Econono" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Econono" />
    <meta name="msapplication-TileColor" content="#1a3d2e" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <!-- Fonts · "Le Carnet" : Fraunces (display serif éditorial) + Figtree (body humanist warm) + Caveat (handwritten accents) + JetBrains Mono (chiffres tabulaires) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,900&family=Figtree:wght@400;500;600;700&family=Caveat:wght@500;700&family=JetBrains+Mono:wght@500;700&display=swap"
    />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="author" content={author || siteConfig.author} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    {!noIndex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <!-- Hreflang -->
    <link rel="alternate" hreflang={siteConfig.locale} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:type" content={imageUrl.endsWith(".svg") ? "image/svg+xml" : "image/png"} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:site_name" content={siteConfig.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && ogType === "article" && <meta property="article:author" content={author} />}
    {articleSection && <meta property="article:section" content={articleSection} />}
    {articleTags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Favicon + App icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#1a3d2e" />

    <!-- PWA manifest -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Sitemaps + discovery -->
    <link rel="alternate" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/xml" title="AI Sitemap" href="/ai-sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title="Econono · le carnet" href="/rss.xml" />
    <link rel="search" type="application/opensearchdescription+xml" title="Econono" href="/opensearch.xml" />
    <link rel="license" href="/rsl.txt" />

    <!-- JSON-LD -->
    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Scroll progress bar -->
    <div id="scroll-progress"></div>
    <!-- Cursor glow (desktop only) -->
    <div id="cursor-glow"></div>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <Analytics />
    <EasterEggs />
    <AutoGlossaire />

    <!-- Animation engine -->
    <script>
      // 1. Intersection Observer for all reveal animations
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: window.innerWidth < 640 ? 0.2 : 0.1, rootMargin: window.innerWidth < 640 ? "0px 0px -120px 0px" : "0px 0px -60px 0px" }
      );
      document.querySelectorAll(
        ".fade-up, .blur-reveal, .scale-reveal, .clip-reveal, .slide-left, .slide-right, .stagger-children, .split-words, .ticker, .drop-cap, .pull-quote-anim, .handwritten-reveal, .num-flip, .path-draw, .border-draw-top, .section-reveal"
      ).forEach((el) => revealObserver.observe(el));

      // 2. Split text into words (wrap each word in a span.word)
      document.querySelectorAll("[data-split-words]").forEach((el) => {
        const text = el.textContent || "";
        el.innerHTML = text
          .split(/\s+/)
          .map((word, i) => `<span class="word" style="transition-delay:${i * 50}ms">${word}</span>`)
          .join(" ");
        el.classList.add("split-words");
        revealObserver.observe(el);
      });

      // 3. Counter animation (animate numbers from 0)
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const target = el.dataset.count || el.textContent || "0";
              const match = target.match(/([+-]?)(\d+)/);
              if (!match) return;
              const prefix = target.replace(/[0-9]/g, "").replace(/(\d)/g, "");
              const sign = match[1];
              const num = parseInt(match[2]);
              const suffix = target.replace(/^[+-]?\d+/, "");
              const pre = target.replace(/\d+.*$/, "");
              let start = 0;
              const duration = 1500;
              const startTime = performance.now();
              function tick(now: number) {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 4);
                const current = Math.round(eased * num);
                el.textContent = `${pre}${current}${suffix}`;
                if (progress < 1) requestAnimationFrame(tick);
              }
              requestAnimationFrame(tick);
              counterObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.3 }
      );
      document.querySelectorAll("[data-count]").forEach((el) => counterObserver.observe(el));

      // 3.5. Scroll progress bar (top of page, gold-to-terracotta gradient)
      const scrollProgressEl = document.getElementById("scroll-progress");
      if (scrollProgressEl) {
        let progressTicking = false;
        function updateScrollProgress() {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const percent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
          (scrollProgressEl as HTMLElement).style.width = `${Math.min(100, percent)}%`;
          progressTicking = false;
        }
        window.addEventListener("scroll", () => {
          if (!progressTicking) {
            requestAnimationFrame(updateScrollProgress);
            progressTicking = true;
          }
        }, { passive: true });
        updateScrollProgress();
      }

      // 3.6. Tilt-on-scroll (wax-seals tournent légèrement)
      const tiltEls = document.querySelectorAll<HTMLElement>("[data-tilt-on-scroll]");
      if (tiltEls.length > 0) {
        let tiltTicking = false;
        window.addEventListener("scroll", () => {
          if (!tiltTicking) {
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              tiltEls.forEach((el) => {
                const rect = el.getBoundingClientRect();
                const center = rect.top + rect.height / 2 - window.innerHeight / 2;
                const tilt = Math.max(-12, Math.min(12, center / 50));
                const baseRotation = parseFloat(el.dataset.baseRotation || "-4");
                el.style.transform = `rotate(${baseRotation + tilt * 0.3}deg)`;
              });
              tiltTicking = false;
            });
            tiltTicking = true;
          }
        }, { passive: true });
      }

      // 3.7. Coin rain · injecte 6-10 pièces aléatoires dans .coin-rain-container
      document.querySelectorAll<HTMLElement>(".coin-rain-container").forEach((container) => {
        const count = parseInt(container.dataset.coinCount || "8");
        for (let i = 0; i < count; i++) {
          const coin = document.createElement("div");
          coin.className = "coin";
          coin.style.left = `${Math.random() * 100}%`;
          coin.style.animationDelay = `${Math.random() * 4}s`;
          coin.style.animationDuration = `${3.5 + Math.random() * 2}s`;
          coin.style.opacity = "1";
          container.appendChild(coin);
        }
      });

      // 3.8. Cursor trail subtle (desktop only) · 8 dots qui suivent le curseur
      if (window.matchMedia("(min-width: 1024px) and (pointer: fine)").matches && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const trailDots: HTMLDivElement[] = [];
        for (let i = 0; i < 8; i++) {
          const dot = document.createElement("div");
          dot.className = "cursor-trail-dot";
          dot.style.opacity = `${0.6 - i * 0.07}`;
          dot.style.transform = `translate(-50%, -50%) scale(${1 - i * 0.08})`;
          document.body.appendChild(dot);
          trailDots.push(dot);
        }
        const trailPositions = trailDots.map(() => ({ x: 0, y: 0 }));
        let mouseX = 0, mouseY = 0;
        document.addEventListener("mousemove", (e) => {
          mouseX = e.clientX; mouseY = e.clientY;
          trailDots.forEach((d) => (d.style.opacity = ""));
        });
        function animateTrail() {
          let prevX = mouseX, prevY = mouseY;
          trailPositions.forEach((pos, i) => {
            pos.x += (prevX - pos.x) * 0.35;
            pos.y += (prevY - pos.y) * 0.35;
            const d = trailDots[i];
            d.style.left = pos.x + "px";
            d.style.top = pos.y + "px";
            prevX = pos.x; prevY = pos.y;
          });
          requestAnimationFrame(animateTrail);
        }
        animateTrail();
      }

      // 4. Parallax on scroll (subtle, performance-safe)
      const parallaxEls = document.querySelectorAll("[data-parallax]");
      if (parallaxEls.length > 0) {
        let ticking = false;
        window.addEventListener("scroll", () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const scrollY = window.scrollY;
              parallaxEls.forEach((el) => {
                const speed = parseFloat((el as HTMLElement).dataset.parallax || "0.1");
                const rect = el.getBoundingClientRect();
                const offset = (rect.top + scrollY - window.innerHeight / 2) * speed;
                (el as HTMLElement).style.transform = `translateY(${offset}px)`;
              });
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }

      // 5. Cursor glow (desktop only, follows mouse)
      const glow = document.getElementById("cursor-glow");
      if (glow && window.matchMedia("(pointer: fine)").matches) {
        let glowX = 0, glowY = 0, targetX = 0, targetY = 0;
        let glowVisible = false;

        document.addEventListener("mousemove", (e) => {
          targetX = e.clientX;
          targetY = e.clientY;
          if (!glowVisible) {
            glow.style.opacity = "1";
            glowVisible = true;
          }
        });

        document.addEventListener("mouseleave", () => {
          glow.style.opacity = "0";
          glowVisible = false;
        });

        // Smooth follow (lerp)
        function animateGlow() {
          glowX += (targetX - glowX) * 0.08;
          glowY += (targetY - glowY) * 0.08;
          glow.style.left = glowX + "px";
          glow.style.top = glowY + "px";
          requestAnimationFrame(animateGlow);
        }
        animateGlow();
      }

      // 6. Magnetic effect on buttons/links with .magnetic class
      if (window.matchMedia("(pointer: fine)").matches) {
        document.querySelectorAll(".magnetic, a[class*='rounded-full']").forEach((el) => {
          const elem = el as HTMLElement;
          const strength = 0.3;

          elem.addEventListener("mousemove", (e: MouseEvent) => {
            const rect = elem.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = (e.clientX - cx) * strength;
            const dy = (e.clientY - cy) * strength;
            elem.style.transform = `translate(${dx}px, ${dy}px)`;
          });

          elem.addEventListener("mouseleave", () => {
            elem.style.transform = "translate(0, 0)";
            elem.style.transition = "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
            setTimeout(() => { elem.style.transition = ""; }, 400);
          });
        });
      }

      // 7. Smooth scroll with easing (Lenis-like, lightweight)
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", (e) => {
          const href = (anchor as HTMLAnchorElement).getAttribute("href");
          if (!href || href === "#") return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();
          const y = target.getBoundingClientRect().top + window.scrollY - 100;
          window.scrollTo({ top: y, behavior: "smooth" });
        });
      });
    </script>
  </body>
</html>
