---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import BrandHero from "../components/BrandHero.astro";
import { siteConfig } from "../../site.config";
import { fullUrl } from "../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs } from "../utils/seo";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category?: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  slug: string;
  keywords?: string;
  lastReviewed?: Date;
  reviewedBy?: string;
}

const {
  title,
  description,
  date,
  author = siteConfig.blog.defaultAuthor,
  category,
  tags = [],
  image,
  imageAlt,
  slug,
  keywords,
  lastReviewed,
  reviewedBy,
} = Astro.props;

const articleUrl = fullUrl(`/blog/${slug}`);
const dateStr = date.toISOString().split("T")[0];

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: siteConfig.blog.name, url: fullUrl("/blog") },
  { name: title, url: articleUrl },
];

const jsonLd = [
  jsonLdArticle({
    title,
    description,
    url: articleUrl,
    datePublished: dateStr,
    image,
    author,
    keywords: keywords?.split(",").map((k) => k.trim()),
  }),
  jsonLdBreadcrumbs(breadcrumbs),
];
---

<BaseLayout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  canonicalUrl={articleUrl}
  ogImage={image}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      {category && (
        <a
          href={`/blog?cat=${category}`}
          class="inline-block bg-primary/10 text-primary text-sm font-medium px-3 py-1 rounded-full mb-4 hover:bg-primary/20 transition-colors"
        >
          {category}
        </a>
      )}
      <h1 class="mb-4">{title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-gray-500 text-sm">
        <span>{author}</span>
        <span>·</span>
        <time datetime={dateStr}>
          {date.toLocaleDateString("fr-FR", {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
        {lastReviewed && (
          <>
            <span>·</span>
            <span>
              Revu le {lastReviewed.toLocaleDateString("fr-FR", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })}
              {reviewedBy && ` par ${reviewedBy}`}
            </span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <figure class="mb-10">
      {image ? (
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full rounded-xl"
          loading="eager"
          width="800"
          height="450"
        />
      ) : (
        <BrandHero title={title} category={category || siteConfig.blog.name} />
      )}
    </figure>

    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
