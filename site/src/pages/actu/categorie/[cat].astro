---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../../site.config";
import { jsonLdBreadcrumbs } from "../../../utils/seo";

const CATEGORY_META: Record<string, { label: string; description: string }> = {
  smic: { label: "SMIC", description: "Revalorisation, calcul net, comparaison annuelle. Tout sur le SMIC français et son impact sur ta paye." },
  livret: { label: "Livrets épargne", description: "Livret A, LEP, LDDS, PEL : taux, plafonds, conditions, stratégie d'allocation." },
  aide: { label: "Aides sociales", description: "Prime d'activité, RSA, APL, allocations familiales : éligibilité, calcul, démarches." },
  fiscalite: { label: "Fiscalité", description: "Impôt sur le revenu, prélèvement à la source, niches, lois de finances." },
  energie: { label: "Énergie", description: "Prix électricité et gaz, MaPrimeRénov, chèques énergie, comparateurs fournisseurs." },
  inflation: { label: "Inflation", description: "Indice INSEE, prix des courses, panier moyen, érosion du pouvoir d'achat." },
  logement: { label: "Logement", description: "Loyers, prix immobilier, encadrement, taxes, droits du locataire." },
  alerte: { label: "Alerte", description: "Mises en garde sur arnaques, démarchages, scams financiers." },
};

export async function getStaticPaths() {
  return Object.keys({
    smic: 1, livret: 1, aide: 1, fiscalite: 1, energie: 1, inflation: 1, logement: 1, alerte: 1,
  }).map((cat) => ({ params: { cat } }));
}

const { cat } = Astro.params;
const meta = CATEGORY_META[cat as string] || { label: cat, description: "" };

let posts: Awaited<ReturnType<typeof getCollection>> = [];
try {
  posts = (await getCollection("actu", ({ data }) => !data.draft && data.category === cat)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
} catch {
  posts = [];
}

const breadcrumbs = jsonLdBreadcrumbs([
  { name: "Accueil", url: siteConfig.url + "/" },
  { name: "Actu pouvoir d'achat", url: siteConfig.url + "/actu/" },
  { name: meta.label, url: siteConfig.url + `/actu/categorie/${cat}/` },
]);
---

<BaseLayout
  title={`Actu ${meta.label.toLowerCase()} · décryptages 2026 · ${siteConfig.name}`}
  description={meta.description || `Toute l'actualité ${meta.label} décryptée par Econono.`}
  jsonLd={[breadcrumbs]}
>
  <section class="pt-12 pb-10 px-4" style="background: #faf7f2;">
    <div class="max-w-6xl mx-auto">
      <nav class="text-xs uppercase tracking-widest mb-6" style="font-family: var(--font-mono); color: #57534e;">
        <a href="/" class="hover:underline">Accueil</a>
        <span class="mx-2 text-stone-300">›</span>
        <a href="/actu/" class="hover:underline">Actu</a>
        <span class="mx-2 text-stone-300">›</span>
        <span style="color: #1a3d2e;">{meta.label}</span>
      </nav>

      <p class="eyebrow mb-3">Catégorie · {posts.length} article{posts.length > 1 ? "s" : ""}</p>
      <h1 style="color: #0f2419; font-family: var(--font-display); font-weight: 700; font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.0;">
        {meta.label}.
      </h1>
      <p class="mt-5 text-lg text-stone-700 max-w-2xl leading-relaxed">{meta.description}</p>
    </div>
  </section>

  <section class="py-16 px-4" style="background: #faf7f2;">
    <div class="max-w-6xl mx-auto">
      {posts.length === 0 ? (
        <div class="ticket p-10 text-center max-w-xl mx-auto">
          <p class="eyebrow mb-2">Bientôt</p>
          <p class="text-stone-600">Pas encore d'article dans cette catégorie. Reviens bientôt.</p>
          <a href="/actu/" class="inline-block mt-4 text-sm font-semibold underline" style="color: #1a3d2e;">← Retour à l'index actu</a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/actu/${post.id}/`} class="ticket p-6 hover-glow group">
              <h3 class="text-lg font-bold mb-2 leading-snug transition-colors group-hover:text-[#c2410c]" style="font-family: var(--font-display); color: #0f2419;">
                {post.data.title}
              </h3>
              <p class="text-stone-600 text-sm line-clamp-3 mb-3 leading-relaxed">{post.data.description}</p>
              <time class="text-xs uppercase tracking-wider" style="font-family: var(--font-mono); color: #57534e;">
                {post.data.date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              </time>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
