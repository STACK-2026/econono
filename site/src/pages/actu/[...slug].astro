---
import ActuLayout from "../../layouts/ActuLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("actu", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<ActuLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  author={post.data.author}
  category={post.data.category}
  impactLevel={post.data.impactLevel}
  keyQuote={post.data.keyQuote}
  tldr={post.data.tldr}
  sources={post.data.sources}
  relatedMetiers={post.data.relatedMetiers}
  relatedGuides={post.data.relatedGuides}
  relatedOutils={post.data.relatedOutils}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  slug={post.id}
  keywords={post.data.keywords}
  lastReviewed={post.data.lastReviewed}
  reviewedBy={post.data.reviewedBy}
>
  <Content />
</ActuLayout>
