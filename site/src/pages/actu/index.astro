---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const CATEGORY_LABELS: Record<string, string> = {
  smic: "SMIC",
  livret: "Livrets épargne",
  aide: "Aides sociales",
  fiscalite: "Fiscalité",
  energie: "Énergie",
  inflation: "Inflation",
  logement: "Logement",
  alerte: "Alerte",
};

let posts: Awaited<ReturnType<typeof getCollection>> = [];
try {
  posts = (await getCollection("actu", ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
} catch (e) {
  posts = [];
}

const breadcrumbs = jsonLdBreadcrumbs([
  { name: "Accueil", url: siteConfig.url + "/" },
  { name: "Actu pouvoir d'achat", url: siteConfig.url + "/actu/" },
]);
---

<BaseLayout
  title={`Actu pouvoir d'achat 2026 · décryptages SMIC, livret A, aides · ${siteConfig.name}`}
  description="L'actualité du pouvoir d'achat décryptée pour de vrai : SMIC, taux livret A et LEP, aides sociales, prix énergie, lois de finances. Sources officielles, mises à jour datées."
  jsonLd={[breadcrumbs]}
>
  <section class="pt-12 pb-10 px-4" style="background: #faf7f2;">
    <div class="max-w-6xl mx-auto">
      <nav class="text-xs uppercase tracking-widest mb-6" style="font-family: var(--font-mono); color: #57534e;">
        <a href="/" class="hover:underline">Accueil</a>
        <span class="mx-2 text-stone-300">›</span>
        <span style="color: #1a3d2e;">Actu pouvoir d'achat</span>
      </nav>

      <p class="eyebrow mb-3">Le décrypteur · pouvoir d'achat</p>
      <h1 style="color: #0f2419; font-family: var(--font-display); font-weight: 700; font-size: clamp(2.4rem, 6vw, 4.4rem); line-height: 1.0;">
        L'actu pouvoir d'achat.
        <span class="block italic mt-2" style="color: #1a3d2e; font-weight: 500;">Décryptée pour de vrai.</span>
      </h1>
      <p class="mt-5 text-lg text-stone-700 max-w-2xl leading-relaxed">
        SMIC, taux du livret A, prime d'activité, prix de l'énergie, lois de finances. On résume, on chiffre, on source. Tu sais ce qui change pour ton budget en moins de 5 minutes.
      </p>
    </div>
  </section>

  <section class="py-16 px-4" style="background: #faf7f2;">
    <div class="max-w-6xl mx-auto">
      {posts.length === 0 ? (
        <div class="ticket p-12 text-center max-w-2xl mx-auto">
          <p class="eyebrow mb-3">Bientôt</p>
          <h2 class="text-2xl mb-4" style="font-family: var(--font-display); font-weight: 700; color: #0f2419;">
            Premier décryptage dans les 24 heures.
          </h2>
          <p class="text-stone-600 mb-6 leading-relaxed max-w-md mx-auto">
            On commence par les chiffres clés 2026 : revalorisation SMIC, taux livret A et LEP, prime d'activité. Reçois la prochaine actu directement dans ta boîte.
          </p>
          <a href="/newsletter/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-white font-semibold text-sm" style="background: #1a3d2e;">
            S'abonner au Carnet
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {posts.map((post) => (
            <a href={`/actu/${post.id}/`} class="ticket p-6 hover-glow group">
              <p class="font-mono text-xs uppercase tracking-wider mb-2" style="color: #c2410c;">{CATEGORY_LABELS[post.data.category] || post.data.category}</p>
              <h3 class="text-lg font-bold mb-2 leading-snug transition-colors group-hover:text-[#c2410c] line-clamp-3" style="font-family: var(--font-display); color: #0f2419;">
                {post.data.title}
              </h3>
              <p class="text-stone-600 text-sm line-clamp-3 mb-3 leading-relaxed">{post.data.description}</p>
              <time class="text-xs uppercase tracking-wider" style="font-family: var(--font-mono); color: #57534e;">
                {post.data.date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              </time>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
