---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../../site.config";
---

<BaseLayout
  title={`Le Signal - Newsletter | ${siteConfig.name}`}
  description="Chaque lundi, l'essentiel de l'impact de l'IA sur l'emploi. Les chiffres, les tendances, les actions concrètes. En 5 minutes."
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-12 sm:py-20 text-center">
    <h1 class="mb-3 sm:mb-4">Le Signal</h1>
    <p class="text-gray-600 text-base sm:text-lg mb-6 sm:mb-8 leading-relaxed">
      Chaque lundi matin, l'essentiel de ce que l'IA change dans le monde du travail. Les études, les chiffres, les tendances, et ce que tu peux faire concrètement. En 5 minutes.
    </p>

    <form id="newsletter-form-page" class="max-w-md mx-auto">
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          name="email"
          required
          placeholder="ton@email.com"
          class="flex-1 px-5 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
        />
        <button
          type="submit"
          class="font-semibold px-6 py-3 rounded-xl text-white transition-all hover:scale-105"
          style={`background: ${siteConfig.colors.primary};`}
        >
          S'abonner
        </button>
      </div>
      <p id="newsletter-page-msg" class="text-xs mt-4 text-gray-500"></p>
      <p class="text-gray-400 text-xs mt-2">
        Pas de spam, pas de revente. Désinscription en un clic.
      </p>
    </form>

    <script>
      const form = document.getElementById("newsletter-form-page");
      const msg = document.getElementById("newsletter-page-msg");
      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = new FormData(form as HTMLFormElement).get("email");
        if (!email) return;
        try {
          const r = await fetch("https://commbksqnwhpsyenjzuf.supabase.co/rest/v1/newsletter_subscribers", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "apikey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNvbW1ia3NxbndocHN5ZW5qenVmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNzM3MjUsImV4cCI6MjA5MTY0OTcyNX0.6igBrd7TAiC5CamU5hmHfEd-JBb4MJuvGAyGHo6tJpU",
              "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNvbW1ia3NxbndocHN5ZW5qenVmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNzM3MjUsImV4cCI6MjA5MTY0OTcyNX0.6igBrd7TAiC5CamU5hmHfEd-JBb4MJuvGAyGHo6tJpU",
              "Prefer": "return=minimal",
            },
            body: JSON.stringify({ email, source: "newsletter-page" }),
          });
          if (r.ok) {
            if (msg) { msg.textContent = "Bienvenue à bord. Tu recevras Le Signal dès lundi prochain."; msg.style.color = "#16a34a"; }
            (form as HTMLFormElement).reset();
          } else if (r.status === 409) {
            if (msg) { msg.textContent = "Tu es déjà inscrit. On se retrouve lundi."; msg.style.color = "#f59e0b"; }
          } else {
            if (msg) { msg.textContent = "Erreur. Réessaie dans quelques instants."; msg.style.color = "#ef4444"; }
          }
        } catch {
          if (msg) { msg.textContent = "Erreur réseau. Réessaie."; msg.style.color = "#ef4444"; }
        }
      });
    </script>

    <div class="mt-10 sm:mt-16 text-left space-y-4 sm:space-y-6">
      <h2 class="text-lg sm:text-xl font-bold">Ce que tu reçois chaque semaine</h2>
      <ul class="space-y-3 sm:space-y-4 text-gray-600 text-sm sm:text-base">
        <li class="flex gap-3">
          <span class="text-primary font-bold">1.</span>
          <span>Le chiffre de la semaine : une donnée clé sur l'impact de l'IA sur l'emploi, sourcee et contextualisée.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-primary font-bold">2.</span>
          <span>L'actu qui compte : les études, les annonces, les tendances que tu ne dois pas rater.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-primary font-bold">3.</span>
          <span>L'action de la semaine : un conseil concret et actionnable pour avancer dans ta reconversion ou ta montee en compétences.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-primary font-bold">4.</span>
          <span>L'outil de la semaine : un outil IA teste et recommande pour ton quotidien professionnel.</span>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
