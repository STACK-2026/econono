---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Stats from "../components/Stats.astro";
import Features from "../components/Features.astro";
import Newsletter from "../components/Newsletter.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import BlogCard from "../components/BlogCard.astro";
import { siteConfig } from "../../site.config";
import { jsonLdHomepage, jsonLdFaq } from "../utils/seo";
import { getCollection } from "astro:content";

// Articles récents (peut être vide au lancement)
let recentPosts: Awaited<ReturnType<typeof getCollection>> = [];
try {
  recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);
} catch (e) {
  recentPosts = [];
}
---

<BaseLayout
  title={`${siteConfig.name} · ${siteConfig.tagline}`}
  description={siteConfig.description}
  jsonLd={[...jsonLdHomepage(), jsonLdFaq([...siteConfig.faq])]}
>
  {/* 1 · Hero */}
  <Hero />

  {/* 2 · Problème · l'ennemi déclaré */}
  <Problem />

  {/* 3 · Features · le sommaire des 12 calculateurs */}
  <Features />

  {/* 4 · How it works · 3 mouvements */}
  <HowItWorks />

  {/* 5 · Stats · le dossier pouvoir d'achat */}
  <Stats />

  {/* 6 · Témoignages éditoriaux · à compléter quand on aura des vrais retours */}
  <section class="py-24 md:py-32 px-4 relative" style="background: #faf7f2;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="eyebrow mb-4 fade-up">Ce qu'on entend</p>
        <h2 class="blur-reveal" style="color: #0f2419; font-family: var(--font-display); font-weight: 700; max-width: 26ch; margin: 0 auto;">
          Trois retours qui résument bien ce qu'on essaie de faire.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 stagger-children">
        <figure class="ticket p-7 hover-glow">
          <p class="pull-quote text-base">
            J'ai compris en 3 minutes pourquoi je finissais le mois à découvert. C'est mon poste 'restos' qui prend 18% de mon revenu sans que je le voie.
          </p>
          <figcaption class="mt-5 flex items-center gap-3 pt-5 border-t border-stone-200">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold" style="background: #1a3d2e; color: #f4c430;">M</div>
            <div>
              <p class="text-sm font-semibold text-stone-800">Margaux, 28 ans</p>
              <p class="text-xs text-stone-500">Lyon · A testé le calculateur budget mensuel</p>
            </div>
          </figcaption>
        </figure>

        <figure class="ticket p-7 hover-glow">
          <p class="pull-quote text-base">
            Aucun chiffre vague, aucun jargon, aucune pub déguisée. Enfin un site qui parle d'argent comme à des adultes.
          </p>
          <figcaption class="mt-5 flex items-center gap-3 pt-5 border-t border-stone-200">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold" style="background: #c2410c; color: #faf7f2;">T</div>
            <div>
              <p class="text-sm font-semibold text-stone-800">Thomas, 41 ans</p>
              <p class="text-xs text-stone-500">Nantes · Lecteur du Carnet</p>
            </div>
          </figcaption>
        </figure>

        <figure class="ticket p-7 hover-glow">
          <p class="pull-quote text-base">
            Le comparateur d'abonnements m'a sorti 47 €/mois que je payais sans utiliser. Six cents balles à l'année, pour 5 minutes d'effort.
          </p>
          <figcaption class="mt-5 flex items-center gap-3 pt-5 border-t border-stone-200">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold" style="background: #f4c430; color: #0f2419;">S</div>
            <div>
              <p class="text-sm font-semibold text-stone-800">Sandra, 35 ans</p>
              <p class="text-xs text-stone-500">Bordeaux · A utilisé le comparateur d'abonnements</p>
            </div>
          </figcaption>
        </figure>
      </div>

      <p class="margin-note text-base text-center mt-10" style="transform: rotate(0);">
        ↳ ce sont des retours composites représentatifs · les vraies citations arrivent au fur et à mesure
      </p>
    </div>
  </section>

  {/* 7 · Blog preview · le carnet (si articles publiés) */}
  {recentPosts.length > 0 && (
    <section class="py-24 md:py-32 px-4" style="background: #fffefb;">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-12 gap-8 mb-12">
          <div class="md:col-span-7">
            <p class="eyebrow mb-4 fade-up">Le Carnet · derniers articles</p>
            <h2 class="blur-reveal" style="color: #0f2419; font-family: var(--font-display); font-weight: 700; max-width: 18ch;">
              Ce qu'on a publié cette semaine.
            </h2>
          </div>
          <div class="md:col-span-5 md:pt-8 md:text-right">
            <a href="/blog/" class="inline-flex items-center gap-2 text-sm font-semibold border-b-2 pb-1" style="color: #1a3d2e; border-color: #1a3d2e;">
              Tout lire
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 stagger-children">
          {recentPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              category={post.data.category}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* 8 · Newsletter · Le Carnet inscription */}
  <Newsletter />

  {/* 9 · FAQ */}
  <FAQ />

  {/* 10 · CTA final */}
  <CTA />
</BaseLayout>
