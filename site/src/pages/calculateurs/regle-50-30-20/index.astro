---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { siteConfig } from "../../../../site.config";
import { jsonLdBreadcrumbs, jsonLdFaq } from "../../../utils/seo";

const breadcrumbs = jsonLdBreadcrumbs([
  { name: "Accueil", url: siteConfig.url + "/" },
  { name: "Calculateurs", url: siteConfig.url + "/calculateurs/" },
  { name: "Règle 50/30/20", url: siteConfig.url + "/calculateurs/regle-50-30-20/" },
]);

const calculatorJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Simulateur règle 50/30/20 · Econono",
  url: siteConfig.url + "/calculateurs/regle-50-30-20/",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Any",
  description: "Applique la règle 50/30/20 à ton revenu : 50% besoins, 30% envies, 20% épargne. Compare avec ta vraie répartition. Gratuit, sans inscription.",
  offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
  inLanguage: "fr-FR",
  publisher: { "@type": "Organization", name: "Econono", url: siteConfig.url },
};

const faqItems = [
  { question: "C'est quoi la règle 50/30/20 ?", answer: "C'est une méthode de répartition du budget popularisée par la sénatrice américaine Elizabeth Warren : 50% des revenus aux besoins essentiels (logement, alimentation, transport, charges, santé), 30% aux envies (loisirs, restos, abonnements, vêtements), 20% à l'épargne et au remboursement de dettes." },
  { question: "La règle 50/30/20 marche-t-elle en France ?", answer: "Théoriquement oui, en pratique difficilement pour les bas revenus en grande ville. Avec le SMIC à Paris où le loyer prend 40-50%, atteindre 50% de besoins est mathématiquement impossible. La règle reste un repère utile pour identifier les déséquilibres, pas un objectif rigide." },
  { question: "Qu'est-ce qui rentre dans 'besoins' (50%) ?", answer: "Tout ce qui est strictement nécessaire pour vivre : loyer/crédit immo, charges (énergie, eau, télécom basique), courses alimentaires de base, transport (essence ou abo), assurances obligatoires (auto, habitation, mutuelle), santé, garde d'enfants si tu travailles, mensualités de crédit en cours." },
  { question: "Qu'est-ce qui rentre dans 'envies' (30%) ?", answer: "Tout ce qui améliore ta vie sans être strictement nécessaire : restos, sorties, voyages, abonnements streaming, vêtements au-delà du minimum, salle de sport, loisirs, cadeaux, restos d'entreprise. La frontière avec les besoins est subjective : un téléphone à 1 200 €, c'est une envie." },
  { question: "Comment atteindre 20% d'épargne ?", answer: "Trois leviers : (1) automatiser un virement vers le livret A le 1er du mois (pay yourself first), (2) cibler les fuites discrètes (abonnements doublons, frais bancaires inutiles, restos non planifiés), (3) augmenter les revenus si possible (négo salaire, second job). Si tu pars de 5%, vise +1 point chaque trimestre, pas 20% du jour au lendemain." },
];
const faqJsonLd = jsonLdFaq(faqItems);
---

<BaseLayout
  title="Règle 50/30/20 calculateur 2026 · Econono"
  description="Applique la règle 50/30/20 à ton revenu : besoins, envies, épargne. Compare avec ta vraie répartition. Méthode Elizabeth Warren."
  jsonLd={[breadcrumbs, calculatorJsonLd, faqJsonLd]}
>
  <section class="pt-10 pb-10 px-4" style="background: #faf7f2;">
    <div class="max-w-6xl mx-auto">
      <nav class="text-xs uppercase tracking-widest mb-6" style="font-family: var(--font-mono); color: #57534e;">
        <a href="/" class="hover:underline">Accueil</a>
        <span class="mx-2 text-stone-300">›</span>
        <a href="/calculateurs/" class="hover:underline">Calculateurs</a>
        <span class="mx-2 text-stone-300">›</span>
        <span style="color: #1a3d2e;">Règle 50/30/20</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow mb-4">Calculateur · 04 · méthode Elizabeth Warren</p>
          <h1 style="color: #0f2419; font-family: var(--font-display); font-weight: 700; font-size: clamp(2.4rem, 6vw, 4.4rem); line-height: 1.0; letter-spacing: -0.025em;">
            Règle 50/30/20.
            <span class="block italic mt-2" style="color: #1a3d2e; font-weight: 500;">La répartition idéale, et ta réalité.</span>
          </h1>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <div class="date-stamp">Mis à jour · 23 avr. 2026</div>
        </div>
      </div>

      <aside data-speakable class="mt-8 max-w-3xl">
        <p>La <strong>règle 50/30/20</strong> est une méthode de répartition du budget : <strong>50% des revenus aux besoins</strong> (logement, alimentation, transport, charges), <strong>30% aux envies</strong> (loisirs, restos, abonnements, vêtements), <strong>20% à l'épargne</strong> ou au remboursement de dettes. Popularisée par la sénatrice américaine Elizabeth Warren. Applicable en France mais difficile pour les bas revenus en grande ville (loyer souvent supérieur à 40%).</p>
      </aside>
    </div>
  </section>

  <section class="px-4 pb-20" style="background: #faf7f2;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-12 gap-8">
        <form id="rule-form" class="lg:col-span-7 ticket p-7 md:p-10 space-y-6" novalidate>
          <header>
            <p class="eyebrow text-xs mb-2">Étape 1 · ton revenu</p>
            <h2 class="text-2xl mb-1" style="font-family: var(--font-display); font-weight: 700; color: #0f2419;">Ton revenu net mensuel</h2>
            <p class="text-sm text-stone-500">Salaire net + aides régulières (APL, allocs, prime d'activité).</p>
          </header>

          <label class="block">
            <div class="relative max-w-xs"><input type="number" name="revenu" min="0" step="50" placeholder="2 000" class="w-full pl-4 pr-10 py-3 rounded-md border-2 text-base font-mono text-right" style="border-color: #e7e5e4; background: #fffefb;" /><span class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-sm text-stone-400">€</span></div>
          </label>

          <hr style="border-color: #e7e5e4;" />

          <header>
            <p class="eyebrow text-xs mb-2">Étape 2 · ta répartition réelle (optionnel)</p>
            <h2 class="text-2xl mb-1" style="font-family: var(--font-display); font-weight: 700; color: #0f2419;">Ce que tu dépenses vraiment</h2>
            <p class="text-sm text-stone-500">Saute cette étape si tu ne sais pas. Sinon on compare avec l'idéal.</p>
          </header>

          <div class="grid sm:grid-cols-3 gap-4">
            <label class="block">
              <span class="block text-sm font-semibold mb-1" style="color: #0f2419;">Besoins</span>
              <div class="relative"><input type="number" name="besoins" min="0" step="10" placeholder="0" class="w-full pl-4 pr-10 py-3 rounded-md border-2 text-base font-mono text-right" style="border-color: #e7e5e4; background: #fffefb;" /><span class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-sm text-stone-400">€</span></div>
              <p class="text-xs text-stone-500 mt-1">Logement, courses, transport, charges</p>
            </label>
            <label class="block">
              <span class="block text-sm font-semibold mb-1" style="color: #0f2419;">Envies</span>
              <div class="relative"><input type="number" name="envies" min="0" step="10" placeholder="0" class="w-full pl-4 pr-10 py-3 rounded-md border-2 text-base font-mono text-right" style="border-color: #e7e5e4; background: #fffefb;" /><span class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-sm text-stone-400">€</span></div>
