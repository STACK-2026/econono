---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { glossaire, glossaireAliases, glossaireCategories, type GlossaireEntry } from "../../data/glossaire";
import { linkifyDefinition, slugifyTerm } from "../../utils/glossaire";
import { siteConfig } from "../../../site.config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const entries = Object.entries(glossaire) as Array<[string, GlossaireEntry]>;
const total = entries.length;

const byCategory: Record<string, Array<[string, GlossaireEntry]>> = {};
for (const [key, entry] of entries) {
  (byCategory[entry.category] ||= []).push([key, entry]);
}
for (const list of Object.values(byCategory)) {
  list.sort(([a], [b]) => a.localeCompare(b, "fr"));
}

const alphabetical = [...entries].sort(([a], [b]) => a.localeCompare(b, "fr"));

const breadcrumbs = jsonLdBreadcrumbs([
  { name: "Accueil", url: siteConfig.url + "/" },
  { name: "Glossaire", url: siteConfig.url + "/glossaire/" },
]);

const slugify = slugifyTerm;

const definedTermSet = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: `Glossaire budget et finances perso · ${siteConfig.name}`,
  description: "Glossaire vulgarisé des termes finance personnelle, budget, crédit, épargne, fiscalité, aides sociales. Pour novices, sans jargon, avec exemples concrets.",
  url: siteConfig.url + "/glossaire/",
  hasDefinedTerm: entries.map(([key, entry]) => ({
    "@type": "DefinedTerm",
    name: key,
    description: entry.definition,
    url: siteConfig.url + `/glossaire/#${slugify(key)}`,
    inDefinedTermSet: siteConfig.url + "/glossaire/",
  })),
};
---

<BaseLayout
  title={`Glossaire budget et finances perso · ${siteConfig.name}`}
  description={`${total} termes finance/budget vulgarisés : reste à vivre, taux endettement, livret A, LEP. Sources officielles.`}
  jsonLd={[breadcrumbs, definedTermSet]}
>
  <section class="pt-12 pb-12 px-4" style="background: #faf7f2;">
    <div class="max-w-5xl mx-auto">
      <nav class="text-xs uppercase tracking-widest mb-6" style="font-family: var(--font-mono); color: #57534e;">
        <a href="/" class="hover:underline">Accueil</a>
        <span class="mx-2 text-stone-300">›</span>
        <span style="color: #1a3d2e;">Glossaire</span>
      </nav>

      <p class="eyebrow mb-3">Glossaire · {total} termes</p>
      <h1 style="color: #0f2419; font-family: var(--font-display); font-weight: 700; font-size: clamp(2.4rem, 6vw, 4.4rem); line-height: 1.0;">
        Tous les mots du budget.
        <span class="block italic mt-2" style="color: #1a3d2e; font-weight: 500;">Vulgarisés.</span>
      </h1>
      <p class="mt-5 text-lg text-stone-700 max-w-2xl leading-relaxed">
        Reste à vivre, taux d'endettement, HCSF, LEP, intérêts composés... Tous les termes finance perso expliqués pour les humains. Avec exemples concrets et sources officielles pour creuser.
      </p>
    </div>
  </section>

  <section class="px-4 pb-8" style="background: #faf7f2;">
    <div class="max-w-5xl mx-auto">
      <nav class="ticket p-5" aria-label="Sommaire glossaire">
        <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: #57534e;">Aller à une catégorie</p>
        <ul class="flex flex-wrap gap-2">
          {glossaireCategories.map((cat) => (
            byCategory[cat.id]?.length > 0 && (
              <li>
                <a
                  href={`#cat-${cat.id}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium border-2 transition-all"
                  style="color: #1a3d2e; border-color: rgba(26, 61, 46, 0.20); background: #fffefb;"
                >
                  <span>{cat.emoji}</span> {cat.label} <span class="text-xs text-stone-400">{byCategory[cat.id].length}</span>
                </a>
              </li>
            )
          ))}
          <li>
            <a
              href="#alphabetique"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold border-2"
              style="color: #faf7f2; background: #1a3d2e; border-color: #1a3d2e;"
            >
              Index A-Z
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </section>

  <section class="py-8 px-4" style="background: #faf7f2;">
    <div class="max-w-5xl mx-auto space-y-14">
      {glossaireCategories.map((cat) => (
        byCategory[cat.id]?.length > 0 && (
          <div id={`cat-${cat.id}`} class="scroll-mt-24">
            <div class="flex items-baseline gap-3 mb-3 pb-3 border-b border-stone-300">
              <span class="text-3xl">{cat.emoji}</span>
              <h2 class="text-2xl md:text-3xl font-bold mb-0" style="font-family: var(--font-display); color: #0f2419;">{cat.label}</h2>
              <span class="font-mono text-xs uppercase tracking-widest text-stone-400 ml-2">{byCategory[cat.id].length} terme{byCategory[cat.id].length > 1 ? "s" : ""}</span>
            </div>
            <p class="text-stone-600 mb-6 leading-relaxed max-w-3xl">{cat.description}</p>
            <div class="grid sm:grid-cols-2 gap-5">
              {byCategory[cat.id].map(([key, entry]) => (
                <article id={slugify(key)} class="ticket p-6 scroll-mt-24 hover-glow">
                  <h3 class="text-xl font-bold capitalize mb-2 leading-snug" style="font-family: var(--font-display); color: #0f2419;">
                    <a href={`#${slugify(key)}`} class="hover:text-[#c2410c] transition-colors">{key}</a>
                  </h3>
                  <p class="text-stone-700 text-sm leading-relaxed mb-3" set:html={linkifyDefinition(entry.definition, glossaire, glossaireAliases, key, 4, "glossaire-card-link")}></p>
                  <p class="text-stone-500 text-xs leading-relaxed border-l-2 px-3 py-2 mb-3" style="background: rgba(244, 196, 48, 0.06); border-color: #f4c430;">
                    <strong style="color: #c2410c;">Ex.</strong> <span set:html={linkifyDefinition(entry.example, glossaire, glossaireAliases, key, 3, "glossaire-card-link")}></span>
                  </p>
                  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs">
                    <a href={entry.internalLink.href} class="font-semibold hover:underline" style="color: #1a3d2e;">
                      → {entry.internalLink.label}
                    </a>
                    <a href={entry.externalSource.url} target="_blank" rel="noopener nofollow" class="text-stone-500 hover:text-stone-700">
                      Source : {entry.externalSource.label} ↗
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        )
      ))}
    </div>
  </section>

  <section id="alphabetique" class="py-16 px-4 scroll-mt-24" style="background: #fffefb;">
    <div class="max-w-5xl mx-auto">
      <h2 class="mb-3" style="font-family: var(--font-display); font-weight: 700; color: #0f2419;">Index alphabétique</h2>
      <p class="text-stone-600 mb-8">Les {total} termes du glossaire en ordre A-Z, lien direct vers la définition.</p>
      <ul class="columns-1 sm:columns-2 md:columns-3 gap-6">
        {alphabetical.map(([key]) => (
          <li class="mb-2 break-inside-avoid">
            <a href={`#${slugify(key)}`} class="text-sm font-medium capitalize hover:underline" style="color: #1a3d2e;">{key}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-16 px-4" style="background: #1a3d2e;">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="mb-4" style="color: #faf7f2; font-family: var(--font-display); font-weight: 700;">Un terme te manque ?</h2>
      <p class="mb-7 max-w-xl mx-auto" style="color: rgba(250, 247, 242, 0.85);">
        On complète le glossaire chaque semaine selon les questions que tu nous remontes. Envoie-nous le terme manquant, on l'ajoute et on te répond dès qu'il est publié.
      </p>
      <a
        href={`mailto:${siteConfig.legal.email}?subject=Glossaire %3A terme manquant`}
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm hover-shine"
        style="background: #f4c430; color: #0f2419;"
      >
        Suggérer un terme
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .glossaire-card-link {
    color: #1a3d2e;
    text-decoration: none;
    background-image: linear-gradient(transparent 70%, rgba(244, 196, 48, 0.45) 70%);
    font-weight: 600;
    padding: 0 2px;
    transition: background-color 0.2s ease, color 0.2s ease;
    border-radius: 2px;
  }
  .glossaire-card-link:hover,
  .glossaire-card-link:focus {
    background-image: none;
    background-color: #1a3d2e;
    color: #faf7f2;
  }
</style>
