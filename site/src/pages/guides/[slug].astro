---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs } from "../../utils/seo";

export async function getStaticPaths() {
  const guides = await getCollection("guides", ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const guideUrl = fullUrl(`/guides/${guide.id}`);
const dateStr = guide.data.date.toISOString().split("T")[0];

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Guides", url: fullUrl("/guides") },
  { name: guide.data.title, url: guideUrl },
];

const jsonLd = [
  jsonLdArticle({
    title: guide.data.title,
    description: guide.data.description,
    url: guideUrl,
    datePublished: dateStr,
    author: guide.data.author || siteConfig.blog.defaultAuthor,
    keywords: guide.data.keywords?.split(",").map((k: string) => k.trim()),
  }),
  jsonLdBreadcrumbs(breadcrumbs),
];
---

<BaseLayout
  title={`${guide.data.title} | ${siteConfig.name}`}
  description={guide.data.description}
  canonicalUrl={guideUrl}
  ogImage={guide.data.image}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      {guide.data.category && (
        <span class="inline-block bg-primary/10 text-primary text-sm font-medium px-3 py-1 rounded-full mb-4">
          {guide.data.category}
        </span>
      )}
      <h1 class="mb-4">{guide.data.title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-gray-500 text-sm">
        <span>{guide.data.author || siteConfig.blog.defaultAuthor}</span>
        <span>·</span>
        <time datetime={dateStr}>
          {guide.data.date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
        </time>
        {guide.data.readingTime && (
          <>
            <span>·</span>
            <span>{guide.data.readingTime} de lecture</span>
          </>
        )}
        {guide.data.lastReviewed && (
          <>
            <span>·</span>
            <span>Mis à jour le {guide.data.lastReviewed.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</span>
          </>
        )}
      </div>
    </header>

    {guide.data.tldr && guide.data.tldr.length > 0 && (
      <aside class="bg-secondary/5 border-l-4 border-secondary rounded-r-xl p-5 sm:p-6 mb-10">
        <div class="text-xs font-bold uppercase tracking-widest text-secondary mb-3">L'essentiel en 30 secondes</div>
        <ul class="space-y-2 text-sm sm:text-base text-gray-800 leading-relaxed">
          {guide.data.tldr.map((point) => (
            <li class="flex gap-2">
              <span class="text-secondary flex-shrink-0 mt-0.5">→</span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <div class="prose max-w-none">
      <Content />
    </div>

    <!-- Maillage interne -->
    <div class="mt-12 p-5 sm:p-6 bg-gray-50 rounded-2xl">
      <p class="font-bold text-base sm:text-lg mb-4">Pour aller plus loin</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/calculateurs" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">📊</span>
          <span class="text-gray-700 font-medium">25 fiches métier avec score IA</span>
        </a>
        <a href="/calculateurs" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">🛠️</span>
          <span class="text-gray-700 font-medium">20 outils IA testés</span>
        </a>
        <a href="/guides/se-former-ia-gratuitement" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">🎓</span>
          <span class="text-gray-700 font-medium">Se former gratuitement</span>
        </a>
        <a href="/newsletter" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">📬</span>
          <span class="text-gray-700 font-medium">Newsletter Le Signal</span>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
