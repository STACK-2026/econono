---
import { siteConfig } from "../../site.config";
---

<section class="py-24 md:py-32 px-4 relative" style="background: #faf7f2;">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-14">
      <p class="eyebrow mb-4 fade-up">Foire aux questions</p>
      <h2 class="blur-reveal" style="color: #0f2419; font-family: var(--font-display); font-weight: 700;">
        On répond aux vraies questions.
      </h2>
      <p class="mt-4 text-stone-600 fade-up" style="transition-delay: 200ms;">
        Pas celles qui arrangent une banque, celles que tu te poses vraiment.
      </p>
    </div>

    <!-- FAQ accordéon style carnet -->
    <div class="space-y-3 stagger-children">
      {siteConfig.faq.map((item, i) => (
        <details class="group ticket overflow-hidden">
          <summary class="cursor-pointer p-5 md:p-6 flex items-start justify-between gap-4 list-none hover:bg-[#fefcf6] transition-colors">
            <div class="flex items-start gap-4">
              <span class="font-mono text-xs font-bold mt-1.5 px-2 py-0.5 rounded" style="background: rgba(244, 196, 48, 0.18); color: #1a3d2e;">
                Q{String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="text-base md:text-lg font-semibold leading-snug" style="font-family: var(--font-display); color: #0f2419;">
                {item.question}
              </h3>
            </div>
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center transition-transform group-open:rotate-45" style="background: rgba(26, 61, 46, 0.08); color: #1a3d2e;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </span>
          </summary>
          <div class="px-5 md:px-6 pb-6 pt-0">
            <div class="ml-0 md:ml-14 pt-2 border-t border-dashed border-stone-200">
              <p class="text-stone-700 leading-relaxed pt-4 text-[15px]">{item.answer}</p>
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Marginalia · question ouverte -->
    <div class="mt-12 text-center fade-up">
      <p class="margin-note text-lg" style="transform: rotate(0);">
        Une question qui ne figure pas ici ?
      </p>
      <a href="mailto:hello@econono.com" class="mt-2 inline-flex items-center gap-2 text-base font-semibold border-b-2 pb-0.5" style="color: #1a3d2e; border-color: #1a3d2e;">
        Écris-nous à hello@econono.com
      </a>
    </div>
  </div>
</section>
