---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image?: string;
  imageAlt?: string;
  category?: string;
}

const { title, description, date, slug, image, imageAlt, category } = Astro.props;

const categoryLabels: Record<string, string> = {
  guide: "Guide",
  astuce: "Astuce",
  comparatif: "Comparatif",
  temoignage: "Témoignage",
  actu: "Actualité",
  decryptage: "Décryptage",
};
const catLabel = category ? (categoryLabels[category] || category) : null;
---

<article class="ticket overflow-hidden hover-glow transition-all">
  <a href={`/blog/${slug}/`} class="block group">
    {image ? (
      <div class="aspect-[16/10] overflow-hidden bg-stone-100">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          width="400"
          height="250"
        />
      </div>
    ) : (
      <div class="aspect-[16/10] flex items-center justify-center" style="background: linear-gradient(135deg, #faf7f2, #f4ecd8);">
        <span class="font-bold text-5xl opacity-30" style="font-family: var(--font-display); color: #1a3d2e;">€</span>
      </div>
    )}
    <div class="p-5">
      {catLabel && (
        <p class="font-mono text-xs uppercase tracking-widest mb-2" style="color: #c2410c;">{catLabel}</p>
      )}
      <h3 class="text-lg font-bold mb-2 leading-snug transition-colors group-hover:text-[#c2410c] line-clamp-3" style="font-family: var(--font-display); color: #0f2419;">
        {title}
      </h3>
      <p class="text-stone-600 text-sm line-clamp-3 mb-3 leading-relaxed">{description}</p>
      <time class="text-xs uppercase tracking-wider" style="font-family: var(--font-mono); color: #57534e;" datetime={date.toISOString().split("T")[0]}>
        {date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
      </time>
    </div>
  </a>
</article>
