---
import { siteConfig } from "../../site.config";
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-stone-200/70 backdrop-blur-sm">
  <!-- Bandeau actu défilant · chiffres pouvoir d'achat -->
  <div
    id="announcement-bar"
    class="w-full overflow-hidden slide-in-top relative"
    role="banner"
    style="background: linear-gradient(90deg, #1a3d2e, #2a5d44, #1a3d2e); background-size: 200% 100%; animation: gradient-shift 12s ease infinite; transition: max-height 0.3s ease, opacity 0.3s ease; max-height: 40px;"
  >
    <a href="/calculateurs/budget-mensuel/" class="block pr-8">
      <div class="announcement-marquee-wrap py-1.5 sm:py-2 text-white overflow-hidden">
        <div class="announcement-marquee-track">
          <span class="announcement-item">💸 <strong style="color:#f4c430">6 Français sur 10</strong> estiment que leur pouvoir d'achat a baissé en 2026</span>
          <span class="announcement-sep">·</span>
          <span class="announcement-item">📈 <strong style="color:#f4c430">+10%</strong> d'inflation cumulée 2022-2024 (INSEE)</span>
          <span class="announcement-sep">·</span>
          <span class="announcement-item">💡 Calcule ton reste à vivre en 30 secondes →</span>
          <span class="announcement-sep">·</span>
          <span class="announcement-item">🪙 SMIC net 2026 : <strong style="color:#f4c430">≈ 1 443 €</strong> · livret A : <strong style="color:#f4c430">2,4%</strong></span>
          <span class="announcement-sep">·</span>
          <span class="announcement-item">💸 <strong style="color:#f4c430">6 Français sur 10</strong> estiment que leur pouvoir d'achat a baissé en 2026</span>
          <span class="announcement-sep">·</span>
          <span class="announcement-item">📈 <strong style="color:#f4c430">+10%</strong> d'inflation cumulée 2022-2024 (INSEE)</span>
          <span class="announcement-sep">·</span>
          <span class="announcement-item">💡 Calcule ton reste à vivre en 30 secondes →</span>
          <span class="announcement-sep">·</span>
        </div>
      </div>
    </a>
    <button
      id="announcement-close"
      class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center text-white/60 hover:text-white transition-opacity z-10"
      aria-label="Fermer l'annonce"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <!-- Logo · pièce + nom serif -->
    <a
      href="/"
      class="flex items-center gap-2.5 font-display text-2xl tracking-tight"
      style={`color: ${siteConfig.colors.primary};`}
    >
      <span class="relative inline-flex items-center justify-center w-9 h-9 rounded-full coin-glint" style="background: linear-gradient(135deg, #fde68a, #f4c430); border: 2px solid #1a3d2e;">
        <span class="font-display font-bold text-base text-[#1a3d2e]">€</span>
      </span>
      <span class="font-bold">Econono</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-7">
      {siteConfig.navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-stone-700 hover:text-[#1a3d2e] transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA newsletter desktop -->
    <a
      href="/newsletter/"
      class="hidden lg:inline-flex items-center gap-2 text-sm font-semibold text-white px-5 py-2 rounded-full transition-all hover:scale-105 hover:shadow-md magnetic"
      style="background: #1a3d2e;"
    >
      Le Carnet · S'abonner
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-stone-700"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t border-stone-100">
    <ul class="px-4 py-3 space-y-1">
      {siteConfig.navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="flex items-center justify-between text-stone-700 font-medium py-3 px-3 rounded-lg hover:bg-stone-50 active:bg-stone-100 transition-colors text-sm"
          >
            {link.label}
            <svg class="w-4 h-4 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </li>
      ))}
    </ul>
    <div class="px-4 pb-4 pt-1">
      <a
        href="/newsletter/"
        class="block text-center text-white font-semibold py-3 text-sm rounded-full transition-all active:scale-[0.98]"
        style="background: #1a3d2e;"
      >
        Le Carnet · S'abonner gratuitement
      </a>
    </div>
  </div>
</header>

<div id="header-spacer" style="height: 90px;"></div>

<script>
  function updateHeaderHeight() {
    const header = document.getElementById("site-header");
    const spacer = document.getElementById("header-spacer");
    if (header && spacer) spacer.style.height = header.offsetHeight + "px";
  }
  updateHeaderHeight();
  window.addEventListener("resize", updateHeaderHeight);

  const bar = document.getElementById("announcement-bar");
  const closeBtn = document.getElementById("announcement-close");
  if (localStorage.getItem("ec_announcement_dismissed")) {
    if (bar) { bar.style.maxHeight = "0"; bar.style.opacity = "0"; bar.style.overflow = "hidden"; }
  }
  closeBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();
    if (bar) { bar.style.maxHeight = "0"; bar.style.opacity = "0"; }
    localStorage.setItem("ec_announcement_dismissed", "1");
    setTimeout(() => updateHeaderHeight(), 350);
  });

  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
  });
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  let lastY = 0;
  const header = document.getElementById("site-header");
  if (window.innerWidth >= 768) {
    window.addEventListener("scroll", () => {
      const y = window.scrollY;
      if (y > 120 && y > lastY) header?.classList.add("-translate-y-full");
      else header?.classList.remove("-translate-y-full");
      lastY = y;
    }, { passive: true });
  }
</script>
