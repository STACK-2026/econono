---
/**
 * Glossaire Tooltip inline.
 * Usage: <Glossaire term="python" display="Python" />
 * Affiche le label souligné en pointillé, hover/tap ouvre un tooltip riche
 * (définition, exemple, lien interne, source externe).
 */
import { glossaire, glossaireAliases, resolveGlossaireKey } from "../data/glossaire";
import { linkifyDefinition } from "../utils/glossaire";

interface Props {
  term: string;
  display?: string;
}

const { term, display } = Astro.props;
const key = resolveGlossaireKey(term);
const entry = key ? glossaire[key] : null;
const label = display || term;

const definitionHtml = entry ? linkifyDefinition(entry.definition, glossaire, glossaireAliases, key ?? undefined) : "";
const exampleHtml = entry ? linkifyDefinition(entry.example, glossaire, glossaireAliases, key ?? undefined) : "";
---

{entry ? (
  <span class="glossaire-term" tabindex="0" role="button" aria-label={`Définition : ${label}`}>
    <span class="glossaire-label">{label}</span>
    <span class="glossaire-tooltip" role="tooltip">
      <span class="glossaire-tooltip-title">{key}</span>
      <span class="glossaire-tooltip-def" set:html={definitionHtml}></span>
      <span class="glossaire-tooltip-example"><strong>Ex.</strong> <span set:html={exampleHtml}></span></span>
      <span class="glossaire-tooltip-links">
        <a href={entry.internalLink.href} class="glossaire-tooltip-internal">
          → {entry.internalLink.label}
        </a>
        <a href={entry.externalSource.url} target="_blank" rel="noopener nofollow" class="glossaire-tooltip-external">
          Source : {entry.externalSource.label} ↗
        </a>
      </span>
    </span>
  </span>
) : (
  <span>{label}</span>
)}

<style is:global>
  .glossaire-term {
    position: relative;
    display: inline;
    cursor: help;
  }

  .glossaire-label {
    border-bottom: 1.5px dotted var(--color-primary);
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .glossaire-term:hover .glossaire-label,
  .glossaire-term:focus .glossaire-label,
  .glossaire-term[aria-expanded="true"] .glossaire-label {
    border-bottom-style: solid;
    border-color: var(--color-primary);
    background-color: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .glossaire-tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    width: max(280px, min(92vw, 360px));
    padding: 16px 18px;
    background: var(--color-secondary);
    color: white;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.55;
    box-shadow: 0 16px 44px -8px rgba(0, 0, 0, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
    pointer-events: none;
    z-index: 1000;
    font-family: var(--font-body);
    font-weight: 400;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 8px;
    white-space: normal;
  }

  .glossaire-tooltip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 7px solid transparent;
    border-top-color: var(--color-secondary);
  }

  .glossaire-term:hover .glossaire-tooltip,
  .glossaire-term:focus .glossaire-tooltip,
  .glossaire-term:focus-within .glossaire-tooltip,
  .glossaire-term[aria-expanded="true"] .glossaire-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .glossaire-tooltip-title {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .glossaire-tooltip-def {
    color: rgba(255, 255, 255, 0.95);
    font-size: 13px;
    line-height: 1.55;
  }

  .glossaire-tooltip-example {
    display: block;
    color: rgba(255, 255, 255, 0.78);
    font-size: 12px;
    line-height: 1.5;
    padding: 8px 10px;
    background: rgba(255, 255, 255, 0.06);
    border-left: 2px solid var(--color-accent);
    border-radius: 4px;
  }

  .glossaire-tooltip-example strong {
    color: var(--color-accent);
    margin-right: 4px;
  }

  .glossaire-tooltip-links {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 2px;
    padding-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 12px;
  }

  .glossaire-tooltip-internal {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .glossaire-tooltip-internal:hover {
    text-decoration: underline;
  }

  .glossaire-tooltip-external {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
  }

  .glossaire-tooltip-external:hover {
    color: white;
    text-decoration: underline;
  }

  /* Mobile : bottom sheet full width */
  @media (max-width: 640px) {
    .glossaire-tooltip {
      position: fixed;
      bottom: 16px;
      left: 16px;
      right: 16px;
      top: auto;
      width: auto;
      transform: translateY(8px);
    }
    .glossaire-tooltip::after {
      display: none;
    }
    .glossaire-term:hover .glossaire-tooltip,
    .glossaire-term:focus .glossaire-tooltip,
    .glossaire-term:focus-within .glossaire-tooltip,
    .glossaire-term[aria-expanded="true"] .glossaire-tooltip {
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glossaire-tooltip {
      transition: none;
    }
  }
</style>
