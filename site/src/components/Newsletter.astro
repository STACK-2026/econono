---
// Newsletter · "Le Carnet" · le rendez-vous éditorial du dimanche
---

<section class="py-24 md:py-32 px-4 relative overflow-hidden" style="background: #fffefb;">
  <!-- Texture papier ligné en arrière plan -->
  <div class="absolute inset-0 ledger-lines opacity-[0.6] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto relative">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <!-- Colonne gauche · headline -->
      <div class="md:col-span-7">
        <p class="eyebrow mb-4 fade-up">Une fois par semaine · le dimanche</p>
        <h2 class="blur-reveal" style="color: #0f2419; font-family: var(--font-display); font-weight: 700; max-width: 18ch;">
          Le Carnet d'Econono.
        </h2>
        <p class="mt-5 text-lg text-stone-700 leading-relaxed max-w-md fade-up" style="transition-delay: 200ms;">
          Une lettre courte, le dimanche matin. Les chiffres qui ont bougé cette semaine, l'astuce qu'on a testée, et un calculateur à essayer.
        </p>
        <p class="mt-3 text-sm text-stone-500 fade-up" style="transition-delay: 300ms;">
          Pas de pub. Pas de revente d'email. Désabonnement en un clic.
        </p>
      </div>

      <!-- Colonne droite · le formulaire dans un ticket -->
      <div class="md:col-span-5">
        <div class="ticket p-7 relative scale-reveal">
          <!-- Sceau dans le coin -->
          <div class="absolute -top-4 -right-3 z-10">
            <div class="wax-seal text-[10px]">Gratuit</div>
          </div>

          <p class="font-mono text-xs uppercase tracking-widest mb-2" style="color: #c2410c;">Inscription</p>
          <h3 class="text-2xl font-bold mb-5 leading-tight" style="font-family: var(--font-display); color: #0f2419;">
            Reçois<br/>la prochaine lettre.
          </h3>

          <form id="newsletter-home-form" class="space-y-3" novalidate>
            <div>
              <label for="nl-email" class="sr-only">Email</label>
              <input
                id="nl-email"
                name="email"
                type="email"
                required
                placeholder="ton.email@exemple.fr"
                class="w-full px-4 py-3 rounded-md border-2 text-base transition-colors focus:outline-none"
                style="border-color: #e7e5e4; background: #faf7f2; font-family: var(--font-mono); font-size: 14px;"
                onfocus="this.style.borderColor='#1a3d2e'"
                onblur="this.style.borderColor='#e7e5e4'"
              />
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-md text-white font-semibold text-sm hover-shine transition-all"
              style="background: #1a3d2e;"
            >
              S'abonner au Carnet
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
            <p id="nl-home-msg" class="text-xs text-center" style="color: #57534e; min-height: 16px;"></p>
          </form>

          <!-- Marginalia handwritten -->
          <p class="mt-4 text-xs text-stone-500 leading-relaxed">
            <span class="handwritten text-base block mb-1" style="color: #c2410c;">en moyenne :</span>
            3 minutes de lecture, le dimanche matin avec ton café.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("newsletter-home-form") as HTMLFormElement | null;
  const msg = document.getElementById("nl-home-msg");
  const SB_URL = "https://rxdcejlofnhjicupzikx.supabase.co";
  const SB_ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ4ZGNlamxvZm5oamljdXB6aWt4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY4OTc2MDUsImV4cCI6MjA5MjQ3MzYwNX0.uG3WBUQ6LBnUxYBzo9LGoxRKU4oSzNlggixjNVSoJIY";

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem("email") as HTMLInputElement)?.value?.trim();
    if (!email) return;
    try {
      const r = await fetch(SB_URL + "/rest/v1/newsletter_subscribers", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "apikey": SB_ANON,
          "Authorization": "Bearer " + SB_ANON,
          "Prefer": "return=minimal",
        },
        body: JSON.stringify({
          email,
          source: "homepage",
          user_agent: navigator.userAgent,
          referrer: document.referrer || null,
        }),
      });
      if (r.ok) {
        if (msg) { msg.textContent = "C'est noté. Premier Carnet dimanche matin."; msg.style.color = "#15803d"; }
        form.reset();
      } else if (r.status === 409) {
        if (msg) { msg.textContent = "Tu es déjà inscrit·e. À dimanche."; msg.style.color = "#ca8a04"; }
      } else {
        if (msg) { msg.textContent = "Erreur réseau. Réessaie."; msg.style.color = "#b91c1c"; }
      }
    } catch {
      if (msg) { msg.textContent = "Erreur réseau. Réessaie."; msg.style.color = "#b91c1c"; }
    }
  });
</script>
