---
// HowItWorks · 3 étapes, présentées comme une recette de carnet artisan
const steps = [
  {
    num: "I",
    title: "Tu poses ton carnet",
    desc: "Tu choisis le calculateur qui parle à ta vraie vie : budget mensuel, reste à vivre, taux d'endettement, comparateur d'abonnements...",
    note: "Aucune inscription. Aucun email. Tu ouvres, tu cliques.",
  },
  {
    num: "II",
    title: "Tu remplis tes lignes",
    desc: "Salaire, loyer, charges, crédits. On te demande juste les chiffres dont on a besoin pour te dire un truc utile.",
    note: "Tes données restent dans ton navigateur. Rien envoyé sur nos serveurs.",
  },
  {
    num: "III",
    title: "Tu lis l'analyse",
    desc: "Pas juste un chiffre brut. Une recommandation : ce poste où tu dépenses 30% de plus que la moyenne, ce livret où tu perds 50 €/an...",
    note: "Avec les sources sous chaque chiffre. Tu peux vérifier.",
  },
];
---

<section class="py-24 md:py-32 px-4 relative" style="background: #fffefb;">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="eyebrow mb-4 fade-up">La méthode · trois mouvements</p>
      <h2 style="color: #0f2419; font-family: var(--font-display); font-weight: 700; max-width: 28ch; margin: 0 auto;">
        <span data-split-words class="block">Comment ça marche, en pratique.</span>
      </h2>
      <p class="mt-4 text-lg text-stone-700 max-w-xl mx-auto fade-up" style="transition-delay: 200ms;">
        On te promet trois minutes. Pas une de plus.
      </p>
    </div>

    <!-- Étapes en colonne avec ligne verticale qui les relie -->
    <div class="relative">
      <!-- Ligne verticale (timeline) -->
      <div class="hidden md:block absolute left-[60px] top-12 bottom-12 w-px" style="background: repeating-linear-gradient(to bottom, #1a3d2e 0, #1a3d2e 6px, transparent 6px, transparent 12px);"></div>

      <ol class="space-y-12 stagger-children">
        {steps.map((step) => (
          <li class="grid grid-cols-[80px_1fr] md:grid-cols-[120px_1fr] gap-5 md:gap-10 items-start">
            <!-- Numéro romain dans cercle vert -->
            <div class="relative flex justify-center">
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center relative z-10" style="background: #1a3d2e; box-shadow: 0 8px 20px -8px rgba(26, 61, 46, 0.4);">
                <span class="font-bold text-2xl md:text-3xl" style="color: #f4c430; font-family: var(--font-display);">{step.num}</span>
              </div>
            </div>

            <div class="pt-2">
              <h3 class="text-2xl md:text-3xl font-bold mb-3 leading-tight" style="font-family: var(--font-display); color: #0f2419;">
                {step.title}
              </h3>
              <p class="text-base md:text-lg text-stone-700 leading-relaxed mb-3 max-w-2xl">
                {step.desc}
              </p>
              <p class="margin-note handwritten-reveal text-base inline-block" style="transform: rotate(-1deg);">
                ↳ {step.note}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- CTA final -->
    <div class="mt-16 text-center fade-up">
      <a
        href="/calculateurs/budget-mensuel/"
        class="inline-flex items-center gap-2.5 px-7 py-4 rounded-full text-white font-semibold text-base hover-shine"
        style="background: #1a3d2e; box-shadow: 0 14px 32px -12px rgba(26, 61, 46, 0.55);"
      >
        Commencer par le budget mensuel
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
