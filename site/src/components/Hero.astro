---
import TextMorph from "./TextMorph.astro";
import ScrambleText from "./ScrambleText.astro";

const promesseAlternatives = [
  "leçons de morale.",
  "jargon bancaire.",
  "pub déguisée.",
  "te culpabiliser.",
  "rien te demander.",
];
const ctaAlternatives = [
  "Calcule mon budget",
  "Vois mon reste à vivre",
  "Trouve mon score santé",
];
---

<section class="relative pt-10 pb-24 md:pt-16 md:pb-32 overflow-hidden" style="background: #faf7f2;">
  <!-- Gradient animé subtil en fond (chaleureux, mouvement permanent) -->
  <div class="absolute inset-0 gradient-animated opacity-[0.07] pointer-events-none" style="background: linear-gradient(135deg, #f4c430, #1a3d2e, #c2410c, #f4c430); background-size: 300% 300%;"></div>
  <!-- Texture papier (grain déjà global, on ajoute un voile chaud) -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 20% 0%, rgba(244, 196, 48, 0.10) 0%, transparent 55%), radial-gradient(ellipse at 90% 100%, rgba(26, 61, 46, 0.06) 0%, transparent 55%);"></div>
  <!-- Pluie de pièces très subtile -->
  <div class="coin-rain-container" data-coin-count="4" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-6 relative">
    <!-- Masthead éditorial : numéro + date + édition + salut contextuel -->
    <div class="flex items-center justify-between mb-8 pb-4 border-b border-stone-300/70 fade-up flex-wrap gap-3">
      <div class="flex items-center gap-3 text-stone-600 text-xs font-mono uppercase tracking-widest">
        <span>N° 001</span>
        <span class="text-stone-300">·</span>
        <span id="greeting-econono">Bienvenue</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="hidden sm:inline-block text-stone-500 text-xs font-mono uppercase tracking-widest">Le Carnet d'Econono</span>
        <span class="hidden sm:inline-block text-stone-300">·</span>
        <span class="handwritten text-base">Édition continue</span>
      </div>
    </div>

    <script is:inline>
      (function () {
        const el = document.getElementById("greeting-econono");
        if (!el) return;
        const h = new Date().getHours();
        let g = "Bienvenue";
        if (h >= 5 && h < 11) g = "Bonjour, prends ton café";
        else if (h >= 11 && h < 14) g = "Bon midi";
        else if (h >= 14 && h < 18) g = "Bel après-midi";
        else if (h >= 18 && h < 22) g = "Bonsoir";
        else g = "C'est tard, on est là quand même";
        el.textContent = g;
      })();
    </script>

    <!-- Layout asymétrique : texte gauche + bloc visuel droite -->
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      <!-- Colonne texte (lg:8) -->
      <div class="lg:col-span-8">
        <p class="eyebrow mb-5 fade-up">
          <span class="inline-flex items-center gap-2">
            <span class="w-2 h-2 rounded-full pulse-signal" style="background: #c2410c;"></span>
            Le numéro un · budget · pouvoir d'achat
          </span>
        </p>

        <h1 style="font-family: var(--font-display); font-weight: 700; line-height: 1.0; letter-spacing: -0.025em; color: #0f2419; font-size: clamp(2.6rem, 6.5vw, 5rem);">
          <span data-split-words class="block">Reprends la main sur ton budget.</span>
          <span class="block mt-2 italic" style="color: #1a3d2e; font-weight: 500;">
            Sans
            <span class="relative inline-block">
              <span style="background-image: linear-gradient(transparent 60%, rgba(244, 196, 48, 0.55) 60%); padding: 0 6px;">
                <TextMorph phrases={promesseAlternatives} interval={2800} class="font-display italic" />
              </span>
            </span>
          </span>
        </h1>

        <!-- Sub-headline éditoriale -->
        <p class="mt-7 text-lg md:text-xl text-stone-700 leading-relaxed max-w-xl fade-up" style="transition-delay: 200ms;">
          Calculateurs gratuits, guides honnêtes, comparatifs sans pub déguisée. Tu sauras enfin <em style="font-family: var(--font-display); font-weight: 500;">ce qu'il te reste vraiment</em>, et quoi en faire.
        </p>

        <!-- CTA primaire + secondaire -->
        <div class="mt-9 flex flex-col sm:flex-row items-start gap-4 fade-up" style="transition-delay: 350ms;">
          <a
            href="/calculateurs/budget-mensuel/"
            class="group inline-flex items-center gap-2.5 px-7 py-4 rounded-full text-white font-semibold text-base hover-shine magnetic glow-pulse"
            style="background: #1a3d2e; box-shadow: 0 14px 32px -12px rgba(26, 61, 46, 0.55); font-family: var(--font-body);"
          >
            <TextMorph phrases={ctaAlternatives} interval={3500} class="font-semibold" />
            <span class="font-mono text-xs opacity-70 normal-case">2 min</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="/calculateurs/"
            class="inline-flex items-center gap-2 px-7 py-4 font-semibold text-base border-b-2 transition-all"
            style="color: #1a3d2e; border-color: #1a3d2e;"
          >
            Voir les 12 calculateurs
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Marginalia handwritten · note du fondateur -->
        <div class="mt-10 max-w-md fade-up" style="transition-delay: 500ms;">
          <p class="margin-note handwritten-reveal text-lg leading-snug">
            Promis, c'est gratuit. Et on ne te demande pas ton numéro de compte.
            <span class="block mt-1 text-sm text-stone-500" style="font-family: var(--font-body); transform: rotate(0); font-weight: 500; font-style: normal;">, l'équipe Econono</span>
          </p>
        </div>
      </div>

      <!-- Colonne visuelle (lg:4) · "billet de calculateur" -->
      <div class="lg:col-span-4">
        <div class="relative scale-reveal" style="transition-delay: 300ms;">
          <!-- Sceau de cire (tilt au scroll) -->
          <div class="absolute -top-4 -right-4 z-10" data-tilt-on-scroll data-base-rotation="-4">
            <div class="wax-seal">Mis à jour · Avr. 2026</div>
          </div>

          <!-- Ticket / fiche calculateur -->
          <div class="ticket ticket-peel p-7">
            <div class="flex items-start justify-between mb-5">
              <div>
                <p class="eyebrow text-xs">Calculateur · 01</p>
                <h3 class="mt-1 text-2xl font-bold leading-tight" style="font-family: var(--font-display); color: #0f2419;">Reste à vivre</h3>
              </div>
              <span class="font-mono text-xs text-stone-400 mt-1.5">N°&nbsp;01</span>
            </div>

            <!-- Lignes ledger style -->
            <div class="space-y-2 mb-5">
              <div class="flex justify-between items-baseline border-b border-dashed border-stone-200 pb-1.5">
                <span class="text-sm text-stone-600">Salaire net</span>
                <span class="font-mono text-sm font-bold text-stone-800 tabular">2 100 €</span>
              </div>
              <div class="flex justify-between items-baseline border-b border-dashed border-stone-200 pb-1.5">
                <span class="text-sm text-stone-600">Loyer</span>
                <span class="font-mono text-sm font-bold tabular" style="color: #c2410c;">- 850 €</span>
              </div>
              <div class="flex justify-between items-baseline border-b border-dashed border-stone-200 pb-1.5">
                <span class="text-sm text-stone-600">Charges</span>
                <span class="font-mono text-sm font-bold tabular" style="color: #c2410c;">- 280 €</span>
              </div>
              <div class="flex justify-between items-baseline border-b border-dashed border-stone-200 pb-1.5">
                <span class="text-sm text-stone-600">Crédits</span>
                <span class="font-mono text-sm font-bold tabular" style="color: #c2410c;">- 190 €</span>
              </div>
            </div>

            <div class="pt-3 border-t-2" style="border-color: #1a3d2e;">
              <div class="flex justify-between items-baseline">
                <span class="text-sm font-semibold" style="color: #1a3d2e;">Reste à vivre</span>
                <span class="font-mono text-2xl font-bold tabular" style="color: #1a3d2e;">780 €</span>
              </div>
              <div class="mt-3 h-2 bg-stone-100 rounded-full overflow-hidden">
                <div class="h-full progress-fill" style="--fill-target: 37%; background: linear-gradient(90deg, #f4c430, #1a3d2e);"></div>
              </div>
              <p class="mt-2 text-xs text-stone-500 leading-relaxed">37% de ton revenu te reste pour vivre. <a href="/calculateurs/reste-a-vivre/" class="underline font-semibold" style="color: #1a3d2e;">Voir la moyenne FR &rsaquo;</a></p>
            </div>
          </div>

          <!-- Note manuscrite à côté du ticket -->
          <p class="margin-note handwritten-reveal absolute -left-2 -bottom-12 text-base hidden lg:block" style="max-width: 180px;">
            ↑ exemple avec un SMIC, un loyer Lyon et une voiture en crédit
          </p>
        </div>
      </div>
    </div>

    <!-- Trust bar style éditorial · 4 mini-arguments avec SVG icons -->
    <div class="mt-20 pt-8 border-t border-stone-300/70 grid grid-cols-2 md:grid-cols-4 gap-6 stagger-children">
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" fill="none" stroke="#1a3d2e" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
        <div>
          <p class="text-sm font-semibold text-stone-800">Sans inscription</p>
          <p class="text-xs text-stone-500 mt-0.5">Aucun email demandé</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" fill="none" stroke="#1a3d2e" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
        </svg>
        <div>
          <p class="text-sm font-semibold text-stone-800">Indépendant</p>
          <p class="text-xs text-stone-500 mt-0.5">Zéro lien bancaire</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" fill="none" stroke="#1a3d2e" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
        <div>
          <p class="text-sm font-semibold text-stone-800">Sources officielles</p>
          <p class="text-xs text-stone-500 mt-0.5">INSEE · Banque de France</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" fill="none" stroke="#1a3d2e" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
        </svg>
        <div>
          <p class="text-sm font-semibold text-stone-800">Chiffres 2026</p>
          <p class="text-xs text-stone-500 mt-0.5">À jour chaque mois</p>
        </div>
      </div>
    </div>
  </div>
</section>
